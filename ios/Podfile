# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

require_relative '../node_modules/react-native-permissions/scripts/setup'

# react-native-permissions: declare only the permissions your app uses
setup_permissions([
  'Microphone',
])

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Define Swift / TF Lite pods that must be built as static frameworks
$static_pods = ['TensorFlowLiteSwift', 'TensorFlowLiteC']

pre_install do |installer|
  installer.pod_targets.each do |pod|
    if $static_pods.include?(pod.name)
      def pod.build_as_static_framework?; true end
      def pod.build_type; Pod::BuildType.static_framework end
    end
  end
end

target 'HearingTriggerRN' do
  config = use_native_modules!

  # YAMNet acoustic scene classification — on-device TFLite inference
  pod 'TensorFlowLiteSwift', '~> 2.14.0'

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'HearingTriggerRNTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
  end
end
