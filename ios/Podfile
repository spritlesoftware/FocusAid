platform :ios, '17.0'

# Define Swift / TF Lite pods that must be built as static frameworks
$static_pods = ['TensorFlowLiteSwift', 'TensorFlowLiteC']

pre_install do |installer|
  installer.pod_targets.each do |pod|
    if $static_pods.include?(pod.name)
      def pod.build_as_static_framework?; true end
      def pod.build_type; Pod::BuildType.static_framework end
    end
  end
end

target 'FocusAid' do
  use_frameworks!

  # YAMNet acoustic scene classification — on-device TFLite inference
  pod 'TensorFlowLiteSwift', '~> 2.14.0'

  target 'FocusAidTests' do
    inherit! :complete
    # Pods for testing
  end
end
